# Copy this file to secrets.toml (same folder) and fill in real values.
# secrets.toml is git-ignored - never commit real keys.
#
# Streamlit reads these as st.secrets["cbbd_api_key"], etc.
#
# NOTE: an earlier commit accidentally put real-looking working keys here
# instead of placeholders (this file IS tracked by git, unlike secrets.toml)
# - fixed to placeholders below. Since those values were committed to git
# history, treat them as burned even though this is a private repo: rotate
# both keys (collegebasketballdata.com/key, the-odds-api.com) and put the
# NEW values only in your local, gitignored secrets.toml, never here.

cbbd_api_key = "YOUR_CBBD_API_KEY_HERE"       # free, no credit card - https://collegebasketballdata.com/key
odds_api_key = "YOUR_ODDS_API_KEY_HERE"       # free tier (~500 credits/mo) - https://the-odds-api.com
